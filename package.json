{
  "name": "moyin-game-v2",
  "private": true,
  "license": "CC-BY-NC-4.0",
  "scripts": {
    "dev": "pnpm --filter @moyin/web dev",
    "build": "pnpm --filter @moyin/web build",
    "preview": "pnpm --filter @moyin/web preview",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @moyin/web test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.55.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
