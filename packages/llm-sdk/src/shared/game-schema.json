        "bgmKey": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Bgmkey"
        },
        "portraits": {
          "anyOf": [
            {
              "items": {},
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Portraits"
        }
      },
      "title": "GameStageHints",
      "type": "object"
    }
