    "GameFrame": {
      "properties": {
        "id": {
          "title": "Id",
          "type": "string"
        },
        "speaker": {
          "title": "Speaker",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "canNext": {
          "default": true,
          "title": "Cannext",
          "type": "boolean"
        }
      },
      "required": [
        "id",
        "speaker",
        "text"
      ],
      "title": "GameFrame",
      "type": "object"
    },
    "GameMeta": {
      "properties": {
        "conversation_id": {
          "title": "Conversation Id",
          "type": "string"
        },
        "response_id": {
          "title": "Response Id",
          "type": "string"
        },
        "candidate_id": {
          "title": "Candidate Id",
          "type": "string"
        },
        "protocolVersion": {
