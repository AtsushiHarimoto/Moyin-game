  "description": "遊戲回合響應 (嚴格 JSON)",
  "properties": {
    "meta": {
      "$ref": "#/$defs/GameMeta"
    },
    "frames": {
      "items": {
        "$ref": "#/$defs/GameFrame"
      },
      "title": "Frames",
      "type": "array"
    },
    "proposals": {
      "items": {
        "$ref": "#/$defs/GameProposal"
      },
      "title": "Proposals",
      "type": "array"
    },
    "stageHints": {
      "anyOf": [
        {
          "$ref": "#/$defs/GameStageHints"
        },
        {
          "type": "null"
        }
      ],
      "default": null
